# ─── NeonWave Backend — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git — add it to .gitignore

# ─── Auth ──────────────────────────────────────────────────────────────────
# Generate a strong secret: run this in terminal → node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=your_super_secret_key_here

# ─── Database (Neon.tech PostgreSQL) ───────────────────────────────────────
# Get this from your Neon dashboard → your project → Connection string
DATABASE_URL=postgresql://<user>:<password>@<host>/<dbname>?sslmode=require
# ─── Cloudflare R2 ─────────────────────────────────────────────────────────
# Account ID: Cloudflare Dashboard → right sidebar
R2_ACCOUNT_ID=your_cloudflare_account_id

# R2 Bucket name (you'll create this)
R2_BUCKET_NAME=neonwave-music

# R2 API Token credentials (Cloudflare → R2 → Manage API tokens)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Public URL for your R2 bucket (enable public access in R2 dashboard)
# Format: https://pub-XXXX.r2.dev  OR your custom domain
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001

# Your frontend URL (for CORS) — use * during development
FRONTEND_URL=http://localhost:5173
